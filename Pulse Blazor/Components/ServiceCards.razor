@inject LanguageService LanguageService

<section class="section-wrap sc-section">
    <div class="section-inner">
        <div class="section-header center">
            <div class="section-eyebrow">@(LanguageService.CurrentLanguage == "en" ? "Our Services" : "Vores ydelser")</div>
            <h2 class="section-title">@if (LanguageService.CurrentLanguage == "en") {
                <text>Marketing is the Foundation. AI is the Evolution.</text>
            } else {
                <text>Markedsføring er fundamentet. AI er evolutionen.</text>
            }</h2>
            <p class="section-desc">
                @if (LanguageService.CurrentLanguage == "en") {
                    <text>We offer two specialized services and one product - designed to work together seamlessly.</text>
                } else {
                    <text>Vi tilbyder to specialiserede ydelser og ét produkt - designet til at virke i tæt samspil med hinanden.</text>
                }
            </p>
        </div>

        <div class="sc-grid">

            <!-- Betalt Markedsføring -->
            <div class="sc-card">
                <div class="sc-bg" style="background-image: url('https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=900&q=80')"></div>
                <div class="sc-overlay"></div>
                <div class="sc-content">
                    <div class="sc-top">
                        <span class="sc-badge">@(LanguageService.CurrentLanguage == "en" ? "SERVICE 01" : "YDELSE 01")</span>
                    </div>
                    <div class="sc-body">
                        <div class="sc-reveal">
                            <div class="sc-tags">
                                <span>Google Ads</span>
                                <span>Meta Ads</span>
                                <span>@(LanguageService.CurrentLanguage == "en" ? "Retargeting" : "Retargeting")</span>
                            </div>
                        </div>
                        <h3 class="sc-title">@(LanguageService.CurrentLanguage == "en" ? "Paid Advertising" : "Betalt markedsføring")</h3>
                    </div>
                    <a href="/paid-ads" class="sc-arrow">→</a>
                </div>
            </div>

            <!-- Professionelle Hjemmesider -->
            <div class="sc-card">
                <div class="sc-bg" style="background-image: url('https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=900&q=80')"></div>
                <div class="sc-overlay"></div>
                <div class="sc-content">
                    <div class="sc-top">
                        <span class="sc-badge">@(LanguageService.CurrentLanguage == "en" ? "SERVICE 02" : "YDELSE 02")</span>
                    </div>
                    <div class="sc-body">
                        <div class="sc-reveal">
                            <div class="sc-tags">
                                <span>@(LanguageService.CurrentLanguage == "en" ? "SEO-optimized" : "SEO-optimeret")</span>
                                <span>@(LanguageService.CurrentLanguage == "en" ? "Mobile-first" : "Mobil-first")</span>
                                <span>@(LanguageService.CurrentLanguage == "en" ? "Fast Delivery" : "Hurtig levering")</span>
                            </div>
                        </div>
                        <h3 class="sc-title">@(LanguageService.CurrentLanguage == "en" ? "Professional Websites" : "Professionelle hjemmesider")</h3>
                    </div>
                    <a href="/hjemmesider" class="sc-arrow">→</a>
                </div>
            </div>

            <!-- Pulse AI -->
            <div class="sc-card">
                <div class="sc-bg" style="background-image: url('https://images.unsplash.com/photo-1677442135703-1787eea5ce01?w=900&q=80')"></div>
                <div class="sc-overlay sc-overlay-ai"></div>
                <div class="sc-content">
                    <div class="sc-top">
                        <span class="sc-badge sc-badge-nyhed">@(LanguageService.CurrentLanguage == "en" ? "NEW" : "NYHED")</span>
                        <span class="sc-badge">@(LanguageService.CurrentLanguage == "en" ? "PRODUCT" : "PRODUKT")</span>
                    </div>
                    <div class="sc-body">
                        <div class="sc-reveal">
                            <div class="sc-tags">
                                <span>@(LanguageService.CurrentLanguage == "en" ? "Under 2 sec response" : "Under 2 sek svartid")</span>
                                <span>@(LanguageService.CurrentLanguage == "en" ? "All Channels" : "Alle kanaler")</span>
                                <span>@(LanguageService.CurrentLanguage == "en" ? "AI-powered" : "AI-drevet")</span>
                                <span>@(LanguageService.CurrentLanguage == "en" ? "24/7 Active" : "24/7 aktiv")</span>
                            </div>
                        </div>
                        <h3 class="sc-title">Pulse AI</h3>
                    </div>
                    <a href="/pulse-ai" class="sc-arrow">→</a>
                </div>
            </div>

        </div>
    </div>
</section>
