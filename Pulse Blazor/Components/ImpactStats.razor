<section class="impact-section">
    <div class="section-inner">
        <div class="impact-grid">
            <div class="impact-item impact-animate" style="--delay: 0;" data-target="340" data-suffix="%">
                <div class="impact-num"><span class="counter">0</span><span class="suffix">%</span></div>
                <div class="impact-label">Gennemsnitlig ROI. Dokumenteret.</div>
            </div>
            <div class="impact-item impact-animate" style="--delay: 1;" data-target="80" data-suffix="%">
                <div class="impact-num"><span class="counter">0</span><span class="suffix">%</span></div>
                <div class="impact-label">Af kundehenvendelser løses af Pulse AI</div>
            </div>
            <div class="impact-item impact-animate" style="--delay: 2;" data-target="60" data-suffix="%">
                <div class="impact-num"><span class="counter">0</span><span class="suffix">%</span></div>
                <div class="impact-label">Lavere supportomkostninger inden for 90 dage</div>
            </div>
            <div class="impact-item impact-animate" style="--delay: 3;" data-target="140" data-suffix="+">
                <div class="impact-num"><span class="counter">0</span><span class="suffix">+</span></div>
                <div class="impact-label">Virksomheder der stoler på os</div>
            </div>
        </div>
    </div>
</section>

@if (IsInitialized)
{
    <script>
        function countUp(el, target, duration) {
            let start = 0;
            const step = target / (duration / 16);
            const tick = () => {
                start = Math.min(start + step, target);
                el.querySelector('.counter').textContent = Math.floor(start);
                if (start < target) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
        }

        setTimeout(() => {
            const items = document.querySelectorAll('.impact-animate');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const delay = (parseFloat(entry.target.style.getPropertyValue('--delay')) || 0) * 150;
                        setTimeout(() => {
                            entry.target.classList.add('animate-in');
                            const target = parseInt(entry.target.dataset.target);
                            countUp(entry.target, target, 1500);
                        }, delay);
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.2 });
            items.forEach(item => observer.observe(item));
        }, 0);
    </script>
}

@code {
    private bool IsInitialized { get; set; } = true;
}
