<section class="cf-section" id="kontakt">
    <div class="section-inner">

        <div class="cf-inner">

            <!-- Left: Text -->
            <div class="cf-left" data-animate="fade-up">
                <div class="cf-eyebrow">Kontakt os</div>
                <h2 class="cf-title">Er du klar til et stærkt samarbejde?</h2>
                <p class="cf-sub">Du er få klik væk. Udfyld formularen, så vender vi tilbage inden for 24 timer — uden salgspres, kun ærlighed.</p>

                <div class="cf-contact-info">
                    <a href="tel:+4512345678" class="cf-contact-item">
                        <div class="cf-contact-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                            </svg>
                        </div>
                        <div>
                            <div class="cf-contact-label">Ring til os</div>
                            <div class="cf-contact-val">+45 12 34 56 78</div>
                        </div>
                    </a>
                    <a href="mailto:hej@tahcillscales.dk" class="cf-contact-item">
                        <div class="cf-contact-icon">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                            </svg>
                        </div>
                        <div>
                            <div class="cf-contact-label">Skriv til os</div>
                            <div class="cf-contact-val">hej@tahcillscales.dk</div>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Right: Form -->
            <div class="cf-form-wrap" data-animate="fade-left" data-delay="120">
                @if (_sent)
                {
                    <div class="cf-success">
                        <div class="cf-success-icon">✓</div>
                        <h3>Besked modtaget!</h3>
                        <p>Vi vender tilbage inden for 24 timer.</p>
                    </div>
                }
                else
                {
                    <form class="cf-form" @onsubmit="Submit" @onsubmit:preventDefault>
                        <div class="cf-row">
                            <div class="cf-field">
                                <label>Navn</label>
                                <input type="text" placeholder="Dit fulde navn" @bind="_name" required />
                            </div>
                            <div class="cf-field">
                                <label>Virksomhed</label>
                                <input type="text" placeholder="Virksomhedens navn" @bind="_company" />
                            </div>
                        </div>
                        <div class="cf-row">
                            <div class="cf-field">
                                <label>Email</label>
                                <input type="email" placeholder="din@email.dk" @bind="_email" required />
                            </div>
                            <div class="cf-field">
                                <label>Telefon</label>
                                <input type="tel" placeholder="+45 00 00 00 00" @bind="_phone" />
                            </div>
                        </div>
                        <div class="cf-field">
                            <label>Hvad kan vi hjælpe med?</label>
                            <textarea placeholder="Fortæl kort om din virksomhed og hvad du ønsker hjælp til..." @bind="_message" rows="4" required></textarea>
                        </div>
                        <button type="submit" class="cf-submit">
                            Send besked
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                            </svg>
                        </button>
                    </form>
                }
            </div>

        </div>
    </div>
</section>

@code {
    private string _name = "", _company = "", _email = "", _phone = "", _message = "";
    private bool _sent = false;

    private void Submit()
    {
        if (!string.IsNullOrWhiteSpace(_name) && !string.IsNullOrWhiteSpace(_email) && !string.IsNullOrWhiteSpace(_message))
        {
            _sent = true;
        }
    }
}
