<section class="tm-section">
    <div class="section-inner">

        <div class="tm-header" data-animate="fade-up">
            <div class="section-eyebrow">Kundeanmeldelser</div>
            <h2 class="tm-title">Betroet af virksomheder<br/>der vil vækste.</h2>
        </div>

        <div class="tm-grid">
            @foreach (var (t, i) in _testimonials.Select((t, i) => (t, i)))
            {
                <div class="tm-card" data-animate="fade-up" data-delay="@(i * 120)">
                    <div class="tm-card-top">
                        <div class="tm-avatar">@t.Initials</div>
                        <div class="tm-company">@t.Company</div>
                    </div>
                    <div class="tm-stars">
                        <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
                    </div>
                    <p class="tm-quote">@t.Quote</p>
                    <div class="tm-author">
                        <div class="tm-name">@t.Name</div>
                        <div class="tm-role">@t.Role</div>
                    </div>
                </div>
            }
        </div>

    </div>
</section>

@code {
    private record Testimonial(string Quote, string Name, string Role, string Initials, string Company);

    private readonly Testimonial[] _testimonials =
    {
        new(
            "Tahcill Scales forstår forretning, ikke blot annoncer. Vores Google Ads ROI steg med 280% på tre måneder. Den slags resultater taler for sig selv.",
            "Lars Andersen", "CEO, Salling Group", "LA", "Salling Group"
        ),
        new(
            "Vores nye hjemmeside konverterer langt bedre end den gamle. Leveret til tiden, inden for budget — og med et design der faktisk afspejler vores brand.",
            "Maria Jensen", "Marketing Director, Bilka", "MJ", "Bilka"
        ),
        new(
            "Pulse AI har frigivet vores supportteam fra de gentagne spørgsmål. 60% lavere supportomkostninger. Det er ikke en small sag for en virksomhed i vores størrelse.",
            "Thomas Nielsen", "Operations Manager, Jysk", "TN", "Jysk"
        ),
    };
}
