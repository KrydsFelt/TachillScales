@inject NavigationManager Nav
@inject IJSRuntime JS

<nav class="nav">
    <div class="nav-inner">
        <a href="/" class="nav-logo">
            <img src="logo.jpeg" alt="Tahcill Scales ikon" style="width:32px;height:32px;object-fit:cover;border-radius:6px;" />
            <span>Tahcill Scales</span>
        </a>

        <ul class="nav-links @(MenuOpen ? "open" : "")">
            <li><a href="/" class="@LinkClass("/")" @onclick="CloseMenu">Hjem</a></li>
            <li class="nav-dropdown">
                <button class="nav-dropdown-toggle @(IsServiceDropdownOpen ? "active" : "")" @onclick="ToggleServiceDropdown">
                    Service & Produkter
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </button>
                <ul class="nav-dropdown-menu @(IsServiceDropdownOpen ? "open" : "")">
                    <li><a href="/paid-ads" @onclick="CloseMenu">Paid Ads</a></li>
                    <li><a href="/hjemmesider" @onclick="CloseMenu">Hjemmesider</a></li>
                    <li><a href="/pulse-ai" @onclick="CloseMenu">Pulse AI</a></li>
                </ul>
            </li>
            <li><a href="@KontaktHref" class="@KontaktClass" @onclick="CloseMenu">Kontakt</a></li>
        </ul>

        <a href="@KontaktHref" class="btn-green">
            Book en samtale
        </a>

        <button class="nav-hamburger @(MenuOpen ? "open" : "")"
                @onclick="ToggleMenu"
                aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

@code {
    private bool MenuOpen = false;
    private bool IsServiceDropdownOpen = false;

    private string CurrentPath =>
        "/" + new Uri(Nav.Uri).AbsolutePath.Trim('/').ToLower();

    private string LinkClass(string path)
    {
        var current = CurrentPath == "/" ? "/" : CurrentPath.TrimEnd('/');
        var target = path == "/" ? "/" : path.TrimEnd('/');
        return current == target ? "active" : "";
    }

    private string KontaktHref => "/kontakt";

    private string KontaktClass => "";

    private void ToggleMenu()
    {
        MenuOpen = !MenuOpen;
    }

    private void ToggleServiceDropdown()
    {
        IsServiceDropdownOpen = !IsServiceDropdownOpen;
    }

    private void CloseMenu()
    {
        MenuOpen = false;
        IsServiceDropdownOpen = false;
    }
}
