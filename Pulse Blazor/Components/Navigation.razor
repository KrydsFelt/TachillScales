@inject NavigationManager Nav
@inject IJSRuntime JS
@inject LanguageService LanguageService

<nav class="nav">
    <div class="nav-inner">
        <a href="/" class="nav-logo">
            <span>TAHCILL SCALES</span>
        </a>

        <ul class="nav-links @(MenuOpen ? "open" : "")">
            <li><a href="/" class="@LinkClass("/")" @onclick="CloseMenu">Hjem</a></li>
            <li class="nav-dropdown">
                <button class="nav-dropdown-toggle @(IsServiceDropdownOpen ? "active" : "")" @onclick="ToggleServiceDropdown">
                    Service & Produkter
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </button>
                <ul class="nav-dropdown-menu @(IsServiceDropdownOpen ? "open" : "")">
                    <li><a href="/paid-ads" @onclick="CloseMenu">Marketing</a></li>
                    <li>
                        <a href="/hjemmesider" @onclick="CloseMenu" class="nav-menu-item-with-badge">
                            <span>Hjemmesider</span>
                            <span class="nav-menu-badge">@(LanguageService.CurrentLanguage == "en" ? "COMING SOON" : "KOMMER SNART")</span>
                        </a>
                    </li>
                    <li>
                        <a href="/pulse-ai" @onclick="CloseMenu" class="nav-menu-item-with-badge">
                            <span>Pulse AI</span>
                            <span class="nav-menu-badge nav-menu-badge-new">@(LanguageService.CurrentLanguage == "en" ? "NEW" : "NYHED")</span>
                        </a>
                    </li>
                </ul>
            </li>
            <li><a href="@KontaktHref" class="@KontaktClass" @onclick="CloseMenu">Kontakt</a></li>
        </ul>

        <div class="nav-cta-group">
            <a href="@KontaktHref" class="btn-green">
                @(LanguageService.CurrentLanguage == "en" ? "Book a call" : "Book en samtale")
            </a>
            <div class="nav-language">
                <button class="nav-lang-toggle @(LanguageService.CurrentLanguage == "da" ? "active" : "")" @onclick="SetLanguageDa" type="button">DA</button>
                <button class="nav-lang-toggle @(LanguageService.CurrentLanguage == "en" ? "active" : "")" @onclick="SetLanguageEn" type="button">EN</button>
            </div>
        </div>

        <button class="nav-hamburger @(MenuOpen ? "open" : "")"
                @onclick="ToggleMenu"
                aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
    </div>

    <div class="nav-mobile-menu @(MenuOpen ? "open" : "")">
        <ul class="nav-mobile-links">
            <li><a href="/" @onclick="CloseMenu">Hjem</a></li>
            <li>
                <button class="nav-mobile-dropdown-toggle @(IsServiceDropdownOpen ? "open" : "")"
                        @onclick="ToggleServiceDropdown">
                    Service & Produkter
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </button>
                <ul class="nav-mobile-submenu @(IsServiceDropdownOpen ? "open" : "")">
                    <li><a href="/paid-ads" @onclick="CloseMenu">Marketing</a></li>
                    <li>
                        <a href="/hjemmesider" @onclick="CloseMenu" class="nav-menu-item-with-badge">
                            <span>Hjemmesider</span>
                            <span class="nav-menu-badge">@(LanguageService.CurrentLanguage == "en" ? "COMING SOON" : "KOMMER SNART")</span>
                        </a>
                    </li>
                    <li>
                        <a href="/pulse-ai" @onclick="CloseMenu" class="nav-menu-item-with-badge">
                            <span>Pulse AI</span>
                            <span class="nav-menu-badge nav-menu-badge-new">@(LanguageService.CurrentLanguage == "en" ? "NEW" : "NYHED")</span>
                        </a>
                    </li>
                </ul>
            </li>
            <li><a href="/kontakt" @onclick="CloseMenu">Kontakt</a></li>
        </ul>
        <div class="nav-mobile-footer">
            <a href="/kontakt" class="btn-green nav-mobile-cta" @onclick="CloseMenu">
                @(LanguageService.CurrentLanguage == "en" ? "Book a call" : "Book en samtale")
            </a>
            <div class="nav-language">
                <button class="nav-lang-toggle @(LanguageService.CurrentLanguage == "da" ? "active" : "")" @onclick="SetLanguageDa" type="button">DA</button>
                <button class="nav-lang-toggle @(LanguageService.CurrentLanguage == "en" ? "active" : "")" @onclick="SetLanguageEn" type="button">EN</button>
            </div>
        </div>
    </div>
</nav>

@code {
    private bool MenuOpen = false;
    private bool IsServiceDropdownOpen = false;

    private string CurrentPath =>
        "/" + new Uri(Nav.Uri).AbsolutePath.Trim('/').ToLower();

    protected override async Task OnInitializedAsync()
    {
        await LanguageService.InitializeAsync();
        LanguageService.Subscribe(StateHasChanged);
    }

    private string LinkClass(string path)
    {
        var current = CurrentPath == "/" ? "/" : CurrentPath.TrimEnd('/');
        var target = path == "/" ? "/" : path.TrimEnd('/');
        return current == target ? "active" : "";
    }

    private string KontaktHref => "/kontakt";

    private string KontaktClass => "";

    private void ToggleMenu()
    {
        MenuOpen = !MenuOpen;
    }

    private void ToggleServiceDropdown()
    {
        IsServiceDropdownOpen = !IsServiceDropdownOpen;
    }

    private void CloseMenu()
    {
        MenuOpen = false;
        IsServiceDropdownOpen = false;
    }

    private async Task SetLanguageDa()
    {
        await LanguageService.SetLanguageAsync("da");
        StateHasChanged();
    }

    private async Task SetLanguageEn()
    {
        await LanguageService.SetLanguageAsync("en");
        StateHasChanged();
    }
}
