@inject NavigationManager Nav
@inject IJSRuntime JS

<nav class="nav">
    <div class="nav-inner">
        <a href="/" class="nav-logo">
            Tahcill Scales
        </a>

        <ul class="nav-links @(MenuOpen ? "open" : "")">
            <li><a href="/" class="@LinkClass("/")" @onclick="CloseMenu">Ydelser</a></li>
            <li><a href="/produkter" class="@LinkClass("/produkter")" @onclick="CloseMenu">Pulse AI</a></li>
            <li><a href="/service" class="@LinkClass("/service")" @onclick="CloseMenu">Om os</a></li>
            <li><a href="@KontaktHref" class="@KontaktClass" @onclick="CloseMenu">Kontakt</a></li>
        </ul>

        <button class="nav-theme-toggle" @onclick="ToggleDarkMode" aria-label="Toggle dark mode" title="Toggle dark mode">
            <svg class="nav-theme-icon sun-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"></circle>
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="nav-theme-icon moon-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
        </button>

        <a href="@KontaktHref" class="btn-green">
            Book en samtale
        </a>

        <button class="nav-hamburger @(MenuOpen ? "open" : "")"
                @onclick="ToggleMenu"
                aria-label="Menu">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>

@code {
    private bool MenuOpen = false;

    private string CurrentPath =>
        "/" + new Uri(Nav.Uri).AbsolutePath.Trim('/').ToLower();

    private string LinkClass(string path)
    {
        var current = CurrentPath == "/" ? "/" : CurrentPath.TrimEnd('/');
        var target = path == "/" ? "/" : path.TrimEnd('/');
        return current == target ? "active" : "";
    }

    private string KontaktHref =>
        CurrentPath == "/" ? "#kontakt" : "/#kontakt";

    private string KontaktClass => "";

    private void ToggleMenu()
    {
        MenuOpen = !MenuOpen;
    }

    private void CloseMenu()
    {
        MenuOpen = false;
    }

    private async Task ToggleDarkMode()
    {
        await JS.InvokeVoidAsync("toggleTheme");
    }
}
