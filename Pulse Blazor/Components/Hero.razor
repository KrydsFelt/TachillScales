@inject LanguageService LanguageService

<section class="hero" id="hjem">
    <div class="hero-bg-grid"></div>
    <div class="hero-inner">

        <!-- Left: Text -->
        <div class="hero-content">
            <div class="hero-live-indicator">
                <div class="hero-live-dot"></div>
                <span>@(LanguageService.CurrentLanguage == "en" ? "+140 Satisfied Customers" : "+140 tilfredse kunder")</span>
            </div>

            <h1 class="hero-title">
                @if (LanguageService.CurrentLanguage == "en") {
                    <text>More Visibility.<br />More Growth.</text>
                } else {
                    <text>Mere synlighed.<br />Mere vækst.</text>
                }
            </h1>

            <p class="hero-desc">
                @if (LanguageService.CurrentLanguage == "en") {
                    <text>Tahcill Scales combines strategic marketing with AI-driven customer service. We help your business grow through targeted visibility and intelligent automation.</text>
                } else {
                    <text>Tahcill Scales kombinerer strategisk markedsføring med AI-drevet kundeservice. Vi hjælper din virksomhed med at vokse gennem målrettet synlighed og intelligent automatisering.</text>
                }
            </p>

            <div class="hero-actions">
                <a href="/kontakt" class="btn-green">
                    @(LanguageService.CurrentLanguage == "en" ? "Book a Strategy Session" : "Book en strategisamtale")
                </a>
            </div>

        </div>

        <!-- Right: Dashboard mockup -->
        <div class="dashboard-wrap">
            <div class="dashboard">
                <!-- Browser chrome -->
                <div class="db-topbar">
                    <div class="db-dots">
                        <div class="db-dot r"></div>
                        <div class="db-dot y"></div>
                        <div class="db-dot g"></div>
                    </div>
                    <div class="db-url">
                        <span class="db-url-lock">🔒</span>
                        app.tachillscales.dk/dashboard
                    </div>
                </div>

                <!-- Dashboard body -->
                <div class="db-body">
                    <div class="db-header">
                        <div class="db-title">@(LanguageService.CurrentLanguage == "en" ? "Marketing Overview" : "Marketing Oversigt")</div>
                        <div class="db-date">@(LanguageService.CurrentLanguage == "en" ? "Mar 2025 - Today" : "Mar 2025 - i dag")</div>
                    </div>

                    <!-- KPI cards -->
                    <div class="db-kpis">
                        <div class="db-kpi">
                            <div class="db-kpi-label">ROI</div>
                            <div class="db-kpi-val pos">+340%</div>
                            <div class="db-kpi-trend">↑ 28% @(LanguageService.CurrentLanguage == "en" ? "vs. last" : "vs. sidst")</div>
                        </div>
                        <div class="db-kpi">
                            <div class="db-kpi-label">@(LanguageService.CurrentLanguage == "en" ? "Conv. Rate" : "Konv. rate")</div>
                            <div class="db-kpi-val pos">+127%</div>
                            <div class="db-kpi-trend">↑ 14% @(LanguageService.CurrentLanguage == "en" ? "vs. last" : "vs. sidst")</div>
                        </div>
                        <div class="db-kpi">
                            <div class="db-kpi-label">@(LanguageService.CurrentLanguage == "en" ? "Traffic" : "Trafik")</div>
                            <div class="db-kpi-val">89K</div>
                            <div class="db-kpi-trend">↑ 22%</div>
                        </div>
                        <div class="db-kpi">
                            <div class="db-kpi-label">ROAS</div>
                            <div class="db-kpi-val pos">4.2x</div>
                            <div class="db-kpi-trend">↑ 0.8x</div>
                        </div>
                    </div>

                    <!-- Bar chart -->
                    <div class="db-chart-area">
                        <div class="db-chart-title">@(LanguageService.CurrentLanguage == "en" ? "Campaign Performance - Monthly Revenue" : "Kampagne performance - Månedlig omsætning")</div>
                        <div class="db-bars">
                            <div class="db-bar-wrap">
                                <div class="db-bar" style="height:30%"></div>
                                <div class="db-bar-lbl">Jan</div>
                            </div>
                            <div class="db-bar-wrap">
                                <div class="db-bar" style="height:42%"></div>
                                <div class="db-bar-lbl">Feb</div>
                            </div>
                            <div class="db-bar-wrap">
                                <div class="db-bar" style="height:38%"></div>
                                <div class="db-bar-lbl">Mar</div>
                            </div>
                            <div class="db-bar-wrap">
                                <div class="db-bar" style="height:55%"></div>
                                <div class="db-bar-lbl">Apr</div>
                            </div>
                            <div class="db-bar-wrap">
                                <div class="db-bar" style="height:62%"></div>
                                <div class="db-bar-lbl">Maj</div>
                            </div>
                            <div class="db-bar-wrap">
                                <div class="db-bar" style="height:70%"></div>
                                <div class="db-bar-lbl">Jun</div>
                            </div>
                            <div class="db-bar-wrap">
                                <div class="db-bar" style="height:78%"></div>
                                <div class="db-bar-lbl">Jul</div>
                            </div>
                            <div class="db-bar-wrap">
                                <div class="db-bar" style="height:85%"></div>
                                <div class="db-bar-lbl">Aug</div>
                            </div>
                            <div class="db-bar-wrap">
                                <div class="db-bar active" style="height:100%"></div>
                                <div class="db-bar-lbl">Sep</div>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom mini cards -->
                    <div class="db-bottom-row">
                        <div class="db-mini-card">
                            <div class="db-mini-icon green">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
                                </svg>
                            </div>
                            <div>
                                <div class="db-mini-label">Google Ads ROAS</div>
                                <div class="db-mini-val" style="color:var(--accent)">4.8x</div>
                            </div>
                        </div>
                        <div class="db-mini-card">
                            <div class="db-mini-icon purple">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                                    <path d="M8 21h8"/><path d="M12 17v4"/>
                                </svg>
                            </div>
                            <div>
                                <div class="db-mini-label">@(LanguageService.CurrentLanguage == "en" ? "New Leads Today" : "Nye leads i dag")</div>
                                <div class="db-mini-val">47</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Floating badge -->
            <div class="db-float-badge">
                <div class="db-float-icon">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/>
                        <polyline points="16 7 22 7 22 13"/>
                    </svg>
                </div>
                <div class="db-float-text">
                    <strong>@(LanguageService.CurrentLanguage == "en" ? "Campaign Active" : "Kampagne aktiv")</strong>
                    @if (LanguageService.CurrentLanguage == "en") {
                        <text>ROI increased +28% this week</text>
                    } else {
                        <text>ROI steg +28% denne uge</text>
                    }
                </div>
            </div>
        </div>

    </div>
</section>

@code {
    protected override void OnInitialized()
    {
        LanguageService.Subscribe(StateHasChanged);
    }

    public void Dispose()
    {
        LanguageService.Unsubscribe(StateHasChanged);
    }
}
