@page "/"
@inject LanguageService LanguageService

<PageTitle>@(LanguageService.CurrentLanguage == "en" ? "Tahcill Scales - Digital Growth & AI" : "Tahcill Scales - Digital Vækst & AI")</PageTitle>

<Navigation />

<!-- Hero -->
<section class="hjem-hero">
    <div class="section-inner">
        <div class="hjem-hero-content">
            <h1 class="hjem-hero-title">
                @if (LanguageService.CurrentLanguage == "en") {
                    <text>Digital visibility drives<br/></text>
                    <span class="hjem-title-italic">real growth</span>
                } else {
                    <text>Digital synlighed driver<br/></text>
                    <span class="hjem-title-italic">rigtig vækst</span>
                }
            </h1>
            <p class="hjem-hero-desc">
                @if (LanguageService.CurrentLanguage == "en") {
                    <text>Tahcill Scales combines strategic marketing, modern websites, and AI-driven customer service. We help your business grow through targeted visibility and intelligent automation.</text>
                } else {
                    <text>Tahcill Scales kombinerer strategisk markedsføring, moderne hjemmesider og AI-drevet kundeservice. Vi hjælper din virksomhed med at vokse gennem målrettet synlighed og intelligent automatisering.</text>
                }
            </p>

            <div class="hjem-hero-stats">
                <div class="hjem-stat-badge">
                    <span class="hjem-stat-icon">⭐</span>
                    <span class="hjem-stat-text">
                        @if (LanguageService.CurrentLanguage == "en") {
                            <text><strong>+140</strong> companies trusted worldwide</text>
                        } else {
                            <text><strong>+140</strong> virksomheder samarbejdet verdenen over</text>
                        }
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About/Philosophy Section -->
<section class="hjem-philosophy">
    <div class="section-inner">
        <blockquote class="hjem-quote">
            @if (LanguageService.CurrentLanguage == "en") {
                <text>We believe in the match. Not every company is for us, and we're not for every company. But when it fits, we know we can create something extraordinary together.</text>
            } else {
                <text>Vi tror på matchet. Ikke enhver virksomhed er for os, og vi er ikke for enhver virksomhed. Men når det passer, ved vi, vi kan skabe noget extraordinært sammen.</text>
            }
        </blockquote>
    </div>
</section>

<!-- Services Cards -->
<section class="hjem-services">
    <div class="section-inner">
        <div class="hjem-services-grid">

            <!-- Paid Ads -->
            <a href="/paid-ads" class="hjem-sc-card">
                <div class="hjem-sc-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
                        <polyline points="16 7 22 7 22 13"></polyline>
                    </svg>
                </div>
                <h3 class="hjem-sc-title">@(LanguageService.CurrentLanguage == "en" ? "Marketing" : "Marketing")</h3>
                <p class="hjem-sc-desc">@(LanguageService.CurrentLanguage == "en" ? "Google & Meta campaigns that maximize your ROI with AI-driven optimization and data-driven strategies." : "Google & Meta kampagner der maksimerer din ROI med AI-drevet optimering og datadrevne strategier.")</p>
                <span class="hjem-sc-link">@(LanguageService.CurrentLanguage == "en" ? "Learn more →" : "Læs mere →")</span>
            </a>

            <!-- Hjemmesider -->
            <a href="/hjemmesider" class="hjem-sc-card">
                <div class="hjem-sc-badge">@(LanguageService.CurrentLanguage == "en" ? "COMING SOON" : "KOMMER SNART")</div>
                <div class="hjem-sc-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>
                    </svg>
                </div>
                <h3 class="hjem-sc-title">@(LanguageService.CurrentLanguage == "en" ? "Websites" : "Hjemmesider")</h3>
                <p class="hjem-sc-desc">@(LanguageService.CurrentLanguage == "en" ? "Custom websites that convert visitors into customers and rank high on Google from day one." : "Skræddersyede hjemmesider der konverterer besøgende til kunder og ranker højt på Google fra dag ét.")</p>
                <span class="hjem-sc-link">@(LanguageService.CurrentLanguage == "en" ? "Learn more →" : "Læs mere →")</span>
            </a>

            <!-- Pulse AI -->
            <a href="/pulse-ai" class="hjem-sc-card">
                <div class="hjem-sc-badge">@(LanguageService.CurrentLanguage == "en" ? "NEW" : "NYHED")</div>
                <div class="hjem-sc-icon hjem-sc-icon--ai">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                </div>
                <h3 class="hjem-sc-title">Pulse AI</h3>
                <p class="hjem-sc-desc">@(LanguageService.CurrentLanguage == "en" ? "Your 24/7 AI sales assistant that never loses a lead - responds, qualifies, and forwards automatically." : "Din 24/7 AI-salgsassistent der aldrig mister et lead - besvarer, kvalificerer og videresender automatisk.")</p>
                <span class="hjem-sc-link">@(LanguageService.CurrentLanguage == "en" ? "Learn more →" : "Læs mere →")</span>
            </a>

            <!-- Featured card - spans full width below -->
            <div class="hjem-sc-featured">
                <div class="hjem-sc-featured-icon">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 17"></polyline>
                        <polyline points="17 6 23 6 23 12"></polyline>
                    </svg>
                </div>
                <div class="hjem-sc-featured-body">
                    <h2 class="hjem-sc-featured-title">@(LanguageService.CurrentLanguage == "en" ? "Your growth starts here." : "Din vækst begynder her.")</h2>
                    <a href="/kontakt" class="hjem-sc-featured-cta">@(LanguageService.CurrentLanguage == "en" ? "Get started →" : "Kom i gang →")</a>
                </div>
            </div>

        </div>
    </div>
</section>

<PulseFooter />

@code {
    protected override void OnInitialized()
    {
        LanguageService.Subscribe(StateHasChanged);
    }

    public void Dispose()
    {
        LanguageService.Unsubscribe(StateHasChanged);
    }
}

<style>
    /* ========== HERO ========== */
    .hjem-hero {
        //position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        padding: 100px 0 80px;
        overflow: hidden;
    }

    .hjem-hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .hjem-hero-title {
        font-size: clamp(36px, 6vw, 56px);
        font-weight: 400;
        line-height: 1.15;
        letter-spacing: -0.5px;
        color: #000;
        margin: 0 0 32px 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', sans-serif;
    }

    .hjem-title-light { font-weight: 300; display: inline; font-style: normal; }
    .hjem-title-italic { font-weight: 700; font-style: normal; display: inline; }

    .hjem-hero-desc {
        font-size: 16px;
        color: #666;
        line-height: 1.75;
        margin: 0 auto 48px;
        max-width: 700px;
        font-weight: 400;
    }

    .hjem-hero-stats {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 60px;
    }

    .hjem-stat-badge {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(59, 130, 246, 0.08);
        padding: 14px 28px;
        border-radius: 50px;
        font-size: 14px;
        color: #333;
    }

    .hjem-stat-icon { font-size: 18px; }
    .hjem-stat-text { font-weight: 500; }
    .hjem-stat-text strong { font-weight: 700; color: #000; }

    /* ========== PHILOSOPHY/QUOTE SECTION ========== */
    .hjem-philosophy {
        padding: 80px 0;
        background: #ffffff;
        margin-top: -200px;
    }

    .hjem-quote {
        line-height: 1.6;
        text-align: center;
        color: #ffffff;
        max-width: 100%;
        margin: 0 auto;
        font-style: italic;
        letter-spacing: -0.3px;
        background: #0a4d28;
        padding: 60px 48px;
        border-radius: 20px;
    }

    /* ========== SERVICES SECTION ========== */
    .hjem-services {
        padding: 80px 0 100px;
        background: #ffffff;
        margin-top: -100px;
        margin-bottom: 50px;

.hjem-services-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
        align-items: stretch;
    }

    /* ── Featured card (dark, spans full width below) ── */
    .hjem-sc-featured {
        grid-column: 1 / -1;
        background: #0f1c2a;
        border-radius: 20px;
        padding: 40px 36px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 240px;
        position: relative;
        overflow: hidden;
    }

    .hjem-sc-featured::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 30% 80%, rgba(34, 197, 94, 0.15) 0%, transparent 60%),
                    radial-gradient(ellipse at 80% 20%, rgba(99, 130, 180, 0.12) 0%, transparent 50%);
        pointer-events: none;
    }

    .hjem-sc-featured-icon {
        width: 48px;
        height: 48px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        position: relative;
        z-index: 1;
    }

    .hjem-sc-featured-body {
        position: relative;
        z-index: 1;
    }

    .hjem-sc-featured-title {
        font-size: 26px;
        font-weight: 800;
        color: #fff;
        line-height: 1.2;
        margin-bottom: 24px;
        letter-spacing: -0.3px;
    }

    .hjem-sc-featured-cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 12px 22px;
        background: #22c55e;
        color: #fff;
        font-size: 14px;
        font-weight: 700;
        border-radius: 50px;
        text-decoration: none;
        transition: all 0.25s ease;
    }

    .hjem-sc-featured-cta:hover {
        background: #16a34a;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(34, 197, 94, 0.35);
    }

    /* ── Service cards (light) ── */
    .hjem-sc-card {
        position: relative;
        background: #fff;
        border-radius: 20px;
        padding: 32px 28px;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        transition: all 0.25s ease;
        border: 1px solid rgba(0, 0, 0, 0.06);
    }

    .hjem-sc-card:hover {
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
        transform: translateY(-3px);
        border-color: rgba(0, 0, 0, 0.1);
    }

    .hjem-sc-badge {
        position: absolute;
        top: 16px;
        right: 16px;
        background: #0f1c2a;
        color: #fff;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        z-index: 5;
    }

    .hjem-sc-icon {
        width: 52px;
        height: 52px;
        background: #0f1c2a;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        margin-bottom: 24px;
        flex-shrink: 0;
    }

    .hjem-sc-icon--ai {
        background: linear-gradient(135deg, #1c2a4a 0%, #2d3a6a 100%);
    }

    .hjem-sc-title {
        font-size: 20px;
        font-weight: 700;
        color: #0a0a0a;
        margin-bottom: 12px;
        line-height: 1.25;
        letter-spacing: -0.2px;
    }

    .hjem-sc-desc {
        font-size: 14px;
        color: #6b7280;
        line-height: 1.7;
        flex: 1;
        margin-bottom: 28px;
    }

    .hjem-sc-link {
        font-size: 14px;
        font-weight: 700;
        color: #0a0a0a;
        display: flex;
        align-items: center;
        gap: 4px;
        transition: gap 0.2s ease;
    }

    .hjem-sc-card:hover .hjem-sc-link {
        gap: 8px;
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 1100px) {
        .hjem-services-grid {
            grid-template-columns: 1fr 1fr 1fr;
        }
    }

    @@media (max-width: 900px) {
        .hjem-services-grid {
            grid-template-columns: 1fr 1fr;
        }
        .hjem-sc-featured {
            grid-column: 1 / -1;
            min-height: 220px;
            flex-direction: row;
            align-items: center;
            gap: 24px;
        }
        .hjem-sc-featured-body {
            display: flex;
            align-items: center;
            gap: 24px;
            flex: 1;
        }
        .hjem-sc-featured-title { margin-bottom: 0; font-size: 22px; }
    }

    @@media (max-width: 640px) {
        .hjem-services-grid {
            grid-template-columns: 1fr;
        }
        .hjem-sc-featured {
            flex-direction: column;
            align-items: flex-start;
        }
        .hjem-sc-featured-body {
            flex-direction: column;
            align-items: flex-start;
        }
        .hjem-sc-featured-title { margin-bottom: 16px; }
    }

    @@media (max-width: 768px) {
        .hjem-hero {
            min-height: 80vh;
            padding: 80px 0 60px;
        }

        .hjem-hero-title { font-size: 25px; }
        .hjem-hero-desc { font-size: 15px; margin: 24px auto 40px; }

        .hjem-hero-stats {
            flex-direction: column;
            gap: 12px;
            margin-bottom: 40px;
        }

        .hjem-stat-badge { justify-content: center; width: 100%; }
        .hjem-hero-cta { padding: 14px 40px; font-size: 13px; }

        .hjem-services { padding: 60px 0 80px; }
    }
</style>
