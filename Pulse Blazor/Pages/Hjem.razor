@page "/"
@inject LanguageService LanguageService

<PageTitle>@(LanguageService.CurrentLanguage == "en" ? "Tahcill Scales - Digital Growth & AI" : "Tahcill Scales - Digital Vækst & AI")</PageTitle>

<Navigation />

<!-- Hero -->
<section class="hjem-hero">
    <div class="section-inner">
        <div class="hjem-hero-content">
            <h1 class="hjem-hero-title">
                @if (LanguageService.CurrentLanguage == "en") {
                    <text>Digital visibility drives<br/></text>
                    <span class="hjem-title-italic">real growth</span>
                } else {
                    <text>Digital synlighed driver<br/></text>
                    <span class="hjem-title-italic">rigtig vækst</span>
                }
            </h1>
            <p class="hjem-hero-desc">
                @if (LanguageService.CurrentLanguage == "en") {
                    <text>Tahcill Scales combines strategic marketing, modern websites, and AI-driven customer service. We help your business grow through targeted visibility and intelligent automation.</text>
                } else {
                    <text>Tahcill Scales kombinerer strategisk markedsføring, moderne hjemmesider og AI-drevet kundeservice. Vi hjælper din virksomhed med at vokse gennem målrettet synlighed og intelligent automatisering.</text>
                }
            </p>

            <div class="hjem-hero-stats">
                <div class="hjem-stat-badge">
                    <span class="hjem-stat-icon">⭐</span>
                    <span class="hjem-stat-text">
                        @if (LanguageService.CurrentLanguage == "en") {
                            <text><strong>+140</strong> companies trusted worldwide</text>
                        } else {
                            <text><strong>+140</strong> virksomheder samarbejdet verdenen over</text>
                        }
                    </span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- About/Philosophy Section -->
<section class="hjem-philosophy">
    <div class="section-inner">
        <blockquote class="hjem-quote">
            @if (LanguageService.CurrentLanguage == "en") {
                <text>We believe in the match. Not every company is for us, and we're not for every company. But when it fits, we know we can create something extraordinary together.</text>
            } else {
                <text>Vi tror på matchet. Ikke enhver virksomhed er for os, og vi er ikke for enhver virksomhed. Men når det passer, ved vi, vi kan skabe noget extraordinært sammen.</text>
            }
        </blockquote>
    </div>
</section>

<PulseFooter />

@code {
    protected override void OnInitialized()
    {
        LanguageService.Subscribe(StateHasChanged);
    }

    public void Dispose()
    {
        LanguageService.Unsubscribe(StateHasChanged);
    }
}

<style>
    /* ========== HERO ========== */
    .hjem-hero {
        //position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        padding: 100px 0 80px;
        overflow: hidden;
    }

    .hjem-hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .hjem-hero-title {
        font-size: clamp(36px, 6vw, 56px);
        font-weight: 400;
        line-height: 1.15;
        letter-spacing: -0.5px;
        color: #000;
        margin: 0 0 32px 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', sans-serif;
    }

    .hjem-title-light { font-weight: 300; display: inline; font-style: normal; }
    .hjem-title-italic { font-weight: 700; font-style: normal; display: inline; }

    .hjem-hero-desc {
        font-size: 16px;
        color: #666;
        line-height: 1.75;
        margin: 0 auto 48px;
        max-width: 700px;
        font-weight: 400;
    }

    .hjem-hero-stats {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 60px;
    }

    .hjem-stat-badge {
        display: flex;
        align-items: center;
        gap: 12px;
        background: rgba(59, 130, 246, 0.08);
        padding: 14px 28px;
        border-radius: 50px;
        font-size: 14px;
        color: #333;
    }

    .hjem-stat-icon { font-size: 18px; }
    .hjem-stat-text { font-weight: 500; }
    .hjem-stat-text strong { font-weight: 700; color: #000; }

    /* ========== PHILOSOPHY/QUOTE SECTION ========== */
    .hjem-philosophy {
        padding: 80px 0;
        background: #ffffff;
        margin-top: -200px;
    }

    .hjem-quote {
        line-height: 1.6;
        text-align: center;
        color: #ffffff;
        max-width: 100%;
        margin: 0 auto;
        font-style: italic;
        letter-spacing: -0.3px;
        background: #0a4d28;
        padding: 60px 48px;
        border-radius: 20px;
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .hjem-hero {
            min-height: 80vh;
            padding: 80px 0 60px;
        }

        .hjem-hero-title { font-size: 25px; }
        .hjem-hero-desc { font-size: 15px; margin: 24px auto 40px; }

        .hjem-hero-stats {
            flex-direction: column;
            gap: 12px;
            margin-bottom: 40px;
        }

        .hjem-stat-badge { justify-content: center; width: 100%; }
        .hjem-hero-cta { padding: 14px 40px; font-size: 13px; }
    }
</style>
