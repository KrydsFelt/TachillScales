@page "/"

<PageTitle>Tahcill Scales — Digital Vækst & AI</PageTitle>

<Navigation />

<!-- Hero -->
<section class="hjem-hero">
    <div class="section-inner">
        <div class="hjem-hero-content">
            <h1 class="hjem-hero-title">
                Skabelse af<br/>
                <span class="hjem-title-light">impactfulde designs med</span><br/>
                <span class="hjem-title-italic">AI-drevne løsninger</span>
            </h1>
            <p class="hjem-hero-desc">Vi fusionerer kreativitet med kunstig intelligens og skaber intuitiv UI-UX design, der presser grænserne for innovation.</p>

            <div class="hjem-hero-stats">
                <div class="hjem-stat-badge">
                    <span class="hjem-stat-icon">⭐</span>
                    <span class="hjem-stat-text"><strong>140+</strong> Virksomheder vokset</span>
                </div>
                <div class="hjem-stat-badge">
                    <span class="hjem-stat-icon">📈</span>
                    <span class="hjem-stat-text"><strong>340%</strong> Gennemsnitlig ROI</span>
                </div>
                <div class="hjem-stat-badge">
                    <span class="hjem-stat-icon">✓</span>
                    <span class="hjem-stat-text"><strong>94%</strong> Kunderetention</span>
                </div>
            </div>

            <a href="/kontakt" class="hjem-hero-cta">LET'S TALK</a>
        </div>
    </div>
</section>

<PulseFooter />

<style>
    /* ========== HERO ========== */
    .hjem-hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        padding: 100px 0 80px;
        overflow: hidden;
    }


    .hjem-hero-content {
        position: relative;
        z-index: 10;
        text-align: center;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .hjem-hero-title {
        font-size: clamp(48px, 9vw, 76px);
        font-weight: 400;
        line-height: 1.15;
        letter-spacing: -0.5px;
        color: #000;
        margin: 0 0 32px 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', sans-serif;
    }

    .hjem-title-light {
        font-weight: 300;
        display: inline;
    }

    .hjem-title-italic {
        font-weight: 700;
        font-style: italic;
        display: inline;
    }

    .hjem-hero-desc {
        font-size: 16px;
        color: #666;
        line-height: 1.75;
        margin: 0 auto 48px;
        max-width: 700px;
        font-weight: 400;
    }

    .hjem-hero-stats {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 20px;
        margin-bottom: 50px;
    }

    .hjem-stat-badge {
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(59, 130, 246, 0.08);
        padding: 12px 24px;
        border-radius: 50px;
        font-size: 13px;
        color: #333;
        white-space: nowrap;
    }

    .hjem-stat-icon {
        font-size: 16px;
    }

    .hjem-stat-text {
        font-weight: 500;
    }

    .hjem-stat-text strong {
        font-weight: 700;
        color: #000;
    }

    .hjem-hero-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 16px 48px;
        background: #0052ff;
        color: white;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.5px;
        border-radius: 50px;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
    }

    .hjem-hero-cta:hover {
        background: #0041cc;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 82, 255, 0.3);
    }


    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .hjem-hero {
            min-height: 80vh;
            padding: 80px 0 60px;
        }

        .hjem-hero-title {
            font-size: 42px;
        }

        .hjem-hero-desc {
            font-size: 15px;
            margin: 24px auto 40px;
        }

        .hjem-hero-stats {
            flex-direction: column;
            gap: 12px;
            margin-bottom: 40px;
        }

        .hjem-stat-badge {
            justify-content: center;
            width: 100%;
        }

        .hjem-hero-cta {
            padding: 14px 40px;
            font-size: 13px;
        }

        .hjem-hero-bg-deco {
            width: 400px;
            height: 400px;
            right: -150px;
        }

    }
</style>
