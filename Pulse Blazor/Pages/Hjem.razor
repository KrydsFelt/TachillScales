@page "/"
@inject LanguageService LanguageService
@inject NavigationManager Nav

<PageTitle>@(LanguageService.CurrentLanguage == "en" ? "Tahcill Scales - Digital Growth & AI" : "Tahcill Scales - Digital Vækst & AI")</PageTitle>

<Navigation />

<div class="hjem-page">
    <!-- About Section -->
    <section class="hjem-about">
        <div class="section-inner">
            <div class="hjem-about-container">
                <!-- Left Column -->
                <div class="hjem-about-left">
                    <span class="hjem-about-label">
                        @if (LanguageService.CurrentLanguage == "en") {
                            <text>about us</text>
                        } else {
                            <text>om os</text>
                        }
                    </span>
                    <h2 class="hjem-about-title">
                        @if (LanguageService.CurrentLanguage == "en") {
                            <text>welcome to tahcill scales</text>
                        } else {
                            <text>velkommen til tahcill scales</text>
                        }
                    </h2>
                    <p class="hjem-about-mission">
                        @if (LanguageService.CurrentLanguage == "en") {
                            <text>Our mission is to enrich peoples' lives through strategic digital solutions, turning ordinary businesses into extraordinary partners. We combine strategic marketing, modern websites, and AI-driven customer service to help your business grow through targeted visibility and intelligent automation.</text>
                        } else {
                            <text>Vores mission er at berige menneskers liv gennem strategiske digitale løsninger, transformere almindelige virksomheder til extraordinære partnere. Vi kombinerer strategisk markedsføring, moderne hjemmesider og AI-drevet kundeservice for at hjælpe din virksomhed med at vokse gennem målrettet synlighed og intelligent automatisering.</text>
                        }
                    </p>
                </div>

                <!-- Right Column -->
                <div class="hjem-about-right-container">
                    <!-- Right Top - Pulse AI Feature -->
                    <button class="hjem-about-right hjem-about-service-card" @onclick="NavigateToServices">
                        <span class="hjem-about-service-badge">@(LanguageService.CurrentLanguage == "en" ? "NEW" : "NYHED")</span>
                        <div class="hjem-about-service-content">
                            <span class="hjem-about-service-label">@(LanguageService.CurrentLanguage == "en" ? "Featured service" : "Udvalgt service")</span>
                            <h3 class="hjem-about-service-title">Pulse AI</h3>
                            <p class="hjem-about-service-copy">
                                @if (LanguageService.CurrentLanguage == "en") {
                                    <text>AI-powered customer service that answers your customers instantly, all day, every day.</text>
                                } else {
                                    <text>AI-drevet kundeservice der svarer dine kunder med det samme, hele dagen, hver dag.</text>
                                }
                            </p>
                        </div>
                    </button>

                    <!-- Right Bottom - Button -->
                    <button class="hjem-about-right-bottom" @onclick="NavigateToServices">
                        @if (LanguageService.CurrentLanguage == "en") {
                            <text>Explore services ↗</text>
                        } else {
                            <text>Udforsk services ↗</text>
                        }
                    </button>
                </div>
            </div>

            <!-- Bottom Section -->
            <div class="hjem-about-bottom">
                <div class="hjem-bottom-content">
                    <h3 class="hjem-bottom-title">
                        @if (LanguageService.CurrentLanguage == "en") {
                            <text>Join here!</text>
                        } else {
                            <text>Join her!</text>
                        }
                    </h3>
                    <p class="hjem-bottom-email">tahcillscales@gmail.com</p>
                    <a href="/kontakt" class="hjem-bottom-btn">
                        <span class="hjem-btn-text-original">
                            @if (LanguageService.CurrentLanguage == "en") {
                                <text>see more <span class="hjem-btn-icon">↗</span></text>
                            } else {
                                <text>se mere <span class="hjem-btn-icon">↗</span></text>
                            }
                        </span>
                        <span class="hjem-btn-text-hover">Let's Go!</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    protected override void OnInitialized()
    {
        LanguageService.Subscribe(StateHasChanged);
    }

    public void Dispose()
    {
        LanguageService.Unsubscribe(StateHasChanged);
    }

    private void NavigateToServices()
    {
        Nav.NavigateTo("/services");
    }
}

<style>
    /* ========== ABOUT SECTION ========== */
    .hjem-page {
        min-height: 100vh;
        background: #f5f5f5;
    }

    .hjem-about {
        padding: 110px 0;
        background: #f5f5f5;
    }

    .hjem-about-container {
        display: grid;
        grid-template-columns: calc(70% - 10px) calc(30% - 10px);
        gap: 20px;
        align-items: stretch;
    }

    .hjem-about-left {
        display: flex;
        flex-direction: column;
        padding: 40px;
        background: white;
        border-radius: 25px;
    }

    .hjem-about-label {
        display: inline-block;
        font-size: 13px;
        font-weight: 500;
        text-transform: lowercase;
        letter-spacing: 1px;
        color: #666;
    }

    .hjem-about-title {
        font-size: 24px;
        font-weight: 400;
        line-height: 1.2;
        letter-spacing: -0.5px;
        color: #000;
        margin: 0;
        text-transform: lowercase;
    }

    .hjem-about-mission {
        font-size: 14px;
        color: #000000;
        line-height: 1.75;
        margin: 0;
        margin-top: auto;
        font-weight: 100;
    }

    .hjem-about-right-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .hjem-about-right {
        position: relative;
        display: flex;
        align-items: flex-end;
        justify-content: flex-start;
        padding: 32px;
        background: linear-gradient(180deg, rgba(11, 23, 37, 0.15) 0%, rgba(11, 23, 37, 0.88) 100%), url('/pulse-ai-customer-service.png');
        background-size: cover;
        background-position: center;
        border-radius: 25px;
        min-height: 350px;
        overflow: hidden;
    }

    .hjem-about-service-card {
        width: 100%;
        border: none;
        text-align: left;
        cursor: pointer;
        transition: transform 0.35s ease, box-shadow 0.35s ease;
        box-shadow: 0 18px 40px rgba(15, 24, 32, 0.22);
    }

    .hjem-about-service-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 26px 48px rgba(15, 24, 32, 0.28);
    }

    .hjem-about-service-badge {
        position: absolute;
        top: 22px;
        right: 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.94);
        color: #0f1820;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
    }

    .hjem-about-service-content {
        max-width: 240px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .hjem-about-service-label {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.78);
    }

    .hjem-about-service-title {
        margin: 0;
        font-size: 30px;
        line-height: 1;
        color: #ffffff;
        font-weight: 600;
    }

    .hjem-about-service-copy {
        margin: 0;
        font-size: 14px;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.92);
    }

    .hjem-about-right-bottom {
        background: #1e3a8a;
        border-radius: 25px;
        padding: 28px 32px;
        min-height: 88px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: none;
        color: white;
        font-size: 15px;
        font-weight: 100;
        cursor: pointer;
        transition: background 0.4s ease-in-out;
    }

    .hjem-about-right-bottom:hover {
        background: #0f1f4a;
    }

    .hjem-about-bottom {
        width: 100%;
        margin-top: 20px;
        padding: 30px;
        background: white;
        border-radius: 25px;
        min-height: 250px;
        position: relative;
        overflow: visible;
        background-image: radial-gradient(circle 25px at 60px 20px, transparent 25px, white 25px);
    }

    .hjem-about-stat-badge {
        position: absolute;
        top: -18px;
        left: 60px;
        display: flex;
        align-items: center;
        gap: 12px;
        background: white;
        padding: 14px 24px;
        border-radius: 25px;
        box-shadow: 0 8px 24px rgba(22, 36, 54, 0.12);
        font-size: 14px;
        color: #333;
        font-weight: 500;
        z-index: 2;
    }

    .hjem-bottom-content {
        display: flex;
        flex-direction: column;
        height: 100%;
        justify-content: space-between;
    }

    .hjem-bottom-title {
        font-size: 25px;
        color: #000;
        margin: 0;
        font-weight: 100;
    }

    .hjem-bottom-email {
        font-size: 16px;
        color: #333;
        margin: 0;
        font-weight: 400;
    }

    .hjem-bottom-btn {
        padding: 14px 48px;
        background: #0f1820;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s;
        position: absolute;
        overflow: hidden;
        height: 50px;
        bottom: 30px;
        right: 30px;
        min-width: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .hjem-bottom-btn:hover {
        background: #333;
        transform: translateY(-2px);
    }

    .hjem-btn-text-original,
    .hjem-btn-text-hover {
        position: absolute;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease-in-out;
        font-weight: 100;
    }

    .hjem-btn-text-original {
        transform: translateY(0);
    }

    .hjem-btn-text-hover {
        transform: translateY(100%);
    }

    .hjem-bottom-btn:hover .hjem-btn-text-original {
        transform: translateY(-100%);
    }

    .hjem-bottom-btn:hover .hjem-btn-text-hover {
        transform: translateY(0);
    }

    .hjem-btn-icon {
        display: inline-block;
        margin-left: 8px;
        transition: transform 0.3s ease-in-out;
    }

    .hjem-bottom-btn:hover .hjem-btn-icon {
        transform: translate(3px, -3px);
    }

    @@keyframes slideText {
        0% { transform: translateY(100%); opacity: 0; }
        100% { transform: translateY(0); opacity: 1; }
    }

    /* ========== RESPONSIVE ========== */
    @@media (max-width: 768px) {
        .hjem-about {
            padding: 140px 0 60px;
        }

        .hjem-about-container {
            grid-template-columns: 1fr;
            gap: 20px;
            align-items: stretch;
        }

        .hjem-about-left {
            padding-right: 0;
            padding: 30px;
            background: white;
            border-radius: 25px;
        }

        .hjem-about-title {
            font-size: 28px;
            margin: 12px 0 0 0;
        }

        .hjem-about-mission {
            font-size: 14px;
            margin-top: auto;
        }

        .hjem-about-right {
            padding: 28px;
            min-height: 280px;
            aspect-ratio: auto;
        }

        .hjem-about-service-badge {
            top: 18px;
            right: 18px;
        }

        .hjem-about-service-title {
            font-size: 26px;
        }

        .hjem-about-right-bottom {
            min-height: 72px;
            padding: 20px 24px;
            font-size: 14px;
        }

        .hjem-about-bottom {
            padding: 30px;
            min-height: auto;
            background-image: none !important;
            position: relative;
        }

        .hjem-bottom-title {
            font-size: 20px;
        }

        .hjem-bottom-email {
            font-size: 14px;
        }

        .hjem-bottom-btn {
            position: static;
            width: auto;
            margin-top: 20px;
            min-width: 140px;
            height: 45px;
            padding: 12px 24px;
        }

        .hjem-btn-text-original,
        .hjem-btn-text-hover {
            display: none !important;
        }

        .hjem-bottom-btn::before {
            content: "kontakt her ↗";
        }
    }
</style>
