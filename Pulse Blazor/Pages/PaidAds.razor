@page "/paid-ads"
@inject LanguageService LanguageService

<PageTitle>@(LanguageService.CurrentLanguage == "en" ? "Marketing - Data-Driven Campaigns | Tahcill Scales" : "Marketing - Datadrevne kampagner | Tahcill Scales")</PageTitle>

<Navigation />

<Hero />

<!-- Benefits Section -->
<section class="pa-benefits">
    <div class="section-inner">
        <div class="pa-benefits-grid">
            <div class="pa-benefit-card">
                <div class="pa-benefit-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 17"></polyline>
                        <polyline points="17 6 23 6 23 12"></polyline>
                    </svg>
                </div>
                <p>@(LanguageService.CurrentLanguage == "en" ? "Maximize ROI through continuous optimization and strategic budget allocation based on live performance data." : "Maksimerer ROI gennem kontinuerlig optimering og strategisk budgetallokeringbaseret på live performance data.")</p>
            </div>
            <div class="pa-benefit-card">
                <div class="pa-benefit-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 6v6l4 2"></path>
                    </svg>
                </div>
                <p>@(LanguageService.CurrentLanguage == "en" ? "Data-driven targeting ensures your ads reach potential customers actively searching for solutions like yours." : "Data-dreven targeting sikrer dine annoncer når de potentielle kunder aktivt søger efter løsninger som dine.")</p>
            </div>
            <div class="pa-benefit-card">
                <div class="pa-benefit-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="2" x2="12" y2="22"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                    </svg>
                </div>
                <p>@(LanguageService.CurrentLanguage == "en" ? "Transparent reporting gives you full control and insight into how every dollar of your marketing budget is spent." : "Transparent rapportering giver dig fuld kontrol og indsigt i hvordan hver krone på marketing bruges.")</p>
            </div>
        </div>
    </div>
</section>

<CTA />

<PulseFooter />

@code {
    protected override void OnInitialized()
    {
        LanguageService.Subscribe(StateHasChanged);
    }

    public void Dispose()
    {
        LanguageService.Unsubscribe(StateHasChanged);
    }
}

<style>
    /* ========== BENEFITS SECTION ========== */
    .pa-benefits {
        padding: 100px 0;
        background: #fff;
    }

    .pa-benefits-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
    }

    .pa-benefit-card {
        background: #f5f5f5;
        border-radius: 16px;
        padding: 36px 28px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .pa-benefit-card:hover {
        background: #efefef;
        transform: translateY(-4px);
    }

    .pa-benefit-icon {
        width: 56px;
        height: 56px;
        background: #0f6d3a;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: white;
        flex-shrink: 0;
    }

    .pa-benefit-card p {
        font-size: 15px;
        color: #666;
        line-height: 1.7;
        margin: 0;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .pa-benefits {
            padding: 80px 0;
        }

        .pa-benefits-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .pa-benefit-card {
            padding: 28px 20px;
        }

        .pa-benefit-icon {
            font-size: 32px;
            margin-bottom: 16px;
        }

        .pa-benefit-card p {
            font-size: 14px;
        }
    }
</style>
