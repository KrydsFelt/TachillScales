@page "/paid-ads"

<PageTitle>Paid Ads — Datadrevne kampagner | Tahcill Scales</PageTitle>

<Navigation />

<Hero />

<!-- Hvad vi leverer -->
<section class="pa-deliver">
    <div class="section-inner">
        <div class="pa-deliver-header" data-animate="fade-up">
            <h2 class="pa-section-title">Hvad vi leverer</h2>
            <p class="pa-section-desc">Strategisk kampagneplanlægning møder AI-drevet optimering for at maksimere din ROI.</p>
        </div>

        <div class="pa-deliver-grid">
            <div class="pa-deliver-item" data-animate="fade-up" data-delay="0">
                <div class="pa-item-num">01</div>
                <h3>Google Ads</h3>
                <p>Search, Display og Performance Max kampagner optimeret til konvertering. Vi maksimerer hver eneste krone.</p>
                <ul class="pa-item-list">
                    <li>Præcis søgeordsmålretning</li>
                    <li>A/B-test & optimering</li>
                    <li>Optimering af konverteringsrate</li>
                </ul>
            </div>

            <div class="pa-deliver-item" data-animate="fade-up" data-delay="100">
                <div class="pa-item-num">02</div>
                <h3>Meta Ads & Remarketing</h3>
                <p>Facebook og Instagram kampagner med præcis målretning. Vi finder din ideale kunde og overbeviser dem.</p>
                <ul class="pa-item-list">
                    <li>Målgruppesegmentering</li>
                    <li>Test af annoncemateriale</li>
                    <li>Lookalike-målgrupper</li>
                </ul>
            </div>

            <div class="pa-deliver-item" data-animate="fade-up" data-delay="200">
                <div class="pa-item-num">03</div>
                <h3>Data & Rapportering</h3>
                <p>Fuldt transparent rapportering med konkrete indsigter. Du ser præcis hvor dine penge går hen.</p>
                <ul class="pa-item-list">
                    <li>Realtids-dashboards</li>
                    <li>Månedlige strategirapporter</li>
                    <li>ROI-sporing</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Resultater -->
<section class="pa-results">
    <div class="section-inner">
        <div class="pa-results-header" data-animate="fade-up">
            <h2 class="pa-section-title">Resultater der taler for sig selv</h2>
        </div>

        <div class="pa-results-grid">
            <div class="pa-result-card" data-animate="fade-up" data-delay="0">
                <div class="pa-result-stat">340%</div>
                <div class="pa-result-label">Gennemsnitlig ROI stigning</div>
            </div>
            <div class="pa-result-card" data-animate="fade-up" data-delay="100">
                <div class="pa-result-stat">2.4x</div>
                <div class="pa-result-label">ROAS på Google Ads</div>
            </div>
            <div class="pa-result-card" data-animate="fade-up" data-delay="200">
                <div class="pa-result-stat">47%</div>
                <div class="pa-result-label">Gennemsnitlig omkostningsreduktion</div>
            </div>
        </div>
    </div>
</section>

<CTA />

<PulseFooter />

