@page "/hjemmesider"
@inject LanguageService LanguageService

<PageTitle>@(LanguageService.CurrentLanguage == "en" ? "Websites - Coming Soon | Tahcill Scales" : "Hjemmesider - Kommer snart | Tahcill Scales")</PageTitle>

<Navigation />

<section class="uc-section">
    <div class="uc-inner">
        <div class="uc-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/>
            </svg>
        </div>
        <div class="uc-tag">@(LanguageService.CurrentLanguage == "en" ? "Under Construction" : "Under konstruktion")</div>
        <h1 class="uc-title">@(LanguageService.CurrentLanguage == "en" ? "We're working on it" : "Vi arbejder på det")</h1>
        <p class="uc-desc">@(LanguageService.CurrentLanguage == "en" ? "Our website service is coming soon. We're building something great - come back soon or reach out to us directly." : "Vores hjemmeside-ydelse er på vej. Vi er i gang med at bygge noget godt - kom tilbage snart, eller skriv til os direkte.")</p>
        <a href="/kontakt" class="uc-cta">@(LanguageService.CurrentLanguage == "en" ? "Contact us in the meantime" : "Kontakt os i mellemtiden")</a>
    </div>
</section>

<PulseFooter />

<style>
    .uc-section {
        min-height: calc(100vh - 72px);
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        padding: 80px 20px;
    }

    .uc-inner {
        text-align: center;
        max-width: 520px;
    }

    .uc-icon {
        width: 72px;
        height: 72px;
        background: #f5f5f5;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1c2a3a;
        margin: 0 auto 24px;
    }

    .uc-tag {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #f59e0b;
        background: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.25);
        padding: 5px 12px;
        border-radius: 20px;
        margin-bottom: 20px;
    }

    .uc-title {
        font-size: clamp(32px, 5vw, 48px);
        font-weight: 800;
        color: #0a0a0a;
        letter-spacing: -0.5px;
        margin-bottom: 16px;
        line-height: 1.15;
    }

    .uc-desc {
        font-size: 16px;
        color: #666;
        line-height: 1.75;
        margin-bottom: 36px;
    }

    .uc-cta {
        display: inline-flex;
        align-items: center;
        padding: 14px 32px;
        background: #0f1c2a;
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        border-radius: 50px;
        text-decoration: none;
        transition: all 0.25s ease;
    }

    .uc-cta:hover {
        background: #1c2a3a;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(15, 28, 42, 0.25);
    }
</style>
