@page "/services"
@inject LanguageService LanguageService
@implements IDisposable

<PageTitle>@(LanguageService.CurrentLanguage == "en" ? "Our Services - Tahcill Scales" : "Vores Services - Tahcill Scales")</PageTitle>

<Navigation />

<section class="services-page">
    <div class="section-inner">
        <div class="services-page-head">
            <div class="services-page-copy">
                <span class="services-page-label">services</span>
                <h2 class="services-page-title">
                    @if (LanguageService.CurrentLanguage == "en")
                    {
                        <text>What we typically help with when a website or digital setup needs to be lifted.</text>
                    }
                    else
                    {
                        <text>Det vi typisk hjælper med, når et website eller digitalt setup skal løftes.</text>
                    }
                </h2>
                <p class="services-page-sub">
                    @if (LanguageService.CurrentLanguage == "en")
                    {
                        <text>We keep it simple and focus on the parts that create the biggest difference for the next version of the business.</text>
                    }
                    else
                    {
                        <text>Vi holder det enkelt og fokuserer på det, der gør størst forskel for næste version af virksomheden.</text>
                    }
                </p>
            </div>

        </div>

        <div class="services-page-grid">
            <a href="/paid-ads" class="services-page-card">
                <div class="services-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M4 19H20" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                        <path d="M7 16V10" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                        <path d="M12 16V6" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                        <path d="M17 16V12" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                        <path d="M6 8L10 5L14 8L18 6" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <h2 class="services-card-title">Meta Ads</h2>
                <p class="services-card-body">
                    @if (LanguageService.CurrentLanguage == "en")
                    {
                        <text>We create campaigns, angles, and follow-up flows that turn traffic into better leads and more qualified conversations.</text>
                    }
                    else
                    {
                        <text>Vi bygger kampagner, vinkler og opfølgning, der gør trafik til bedre leads og mere kvalificerede samtaler.</text>
                    }
                </p>
            </a>

            <a href="/hjemmesider" class="services-page-card">
                <div class="services-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <rect x="4" y="5" width="16" height="14" rx="2.5" stroke="currentColor" stroke-width="1.9"/>
                        <path d="M4 9H20" stroke="currentColor" stroke-width="1.9"/>
                        <path d="M8 13H11" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                        <path d="M8 16H15" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                    </svg>
                </div>
                <h2 class="services-card-title">
                    @(LanguageService.CurrentLanguage == "en" ? "Websites" : "Hjemmesider")
                </h2>
                <p class="services-card-body">
                    @if (LanguageService.CurrentLanguage == "en")
                    {
                        <text>We design and build websites that sharpen first impressions, create trust fast, and make the next step easier for the customer.</text>
                    }
                    else
                    {
                        <text>Vi designer og bygger hjemmesider, der skærper førstehåndsindtrykket, skaber tillid hurtigt og gør næste skridt lettere for kunden.</text>
                    }
                </p>
            </a>

            <a href="/pulse-ai" class="services-page-card">
                <span class="services-card-badge">@(LanguageService.CurrentLanguage == "en" ? "NEW" : "NYHED")</span>
                <div class="services-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M7 8H17" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                        <path d="M7 12H17" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                        <path d="M7 16H13" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
                        <rect x="5" y="4" width="14" height="16" rx="2.5" stroke="currentColor" stroke-width="1.9"/>
                    </svg>
                </div>
                <h2 class="services-card-title">Pulse AI</h2>
                <p class="services-card-body">
                    @if (LanguageService.CurrentLanguage == "en")
                    {
                        <text>We build AI customer service that answers instantly, reduces repetitive work, and gives your team more room to focus on the cases that matter.</text>
                    }
                    else
                    {
                        <text>Vi bygger AI-kundeservice, der svarer med det samme, reducerer gentaget arbejde og giver dit team mere plads til de sager, der betyder noget.</text>
                    }
                </p>
            </a>
        </div>
    </div>
</section>

<PulseFooter />

<style>
    .services-page {
        padding: 150px 0 90px;
        background:
            radial-gradient(circle at top right, rgba(255,255,255,0.08) 0%, transparent 24%),
            linear-gradient(180deg, #0d141c 0%, #121821 100%);
    }

    .services-page-head {
        display: flex;
        justify-content: flex-start;
        align-items: flex-start;
        gap: 24px;
        margin-bottom: 38px;
    }

    .services-page-copy {
        max-width: 1080px;
    }

    .services-page-label {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 32px;
        padding: 0 14px;
        border-radius: 999px;
        background: #ffffff;
        color: #617286;
        font-size: 0.8rem;
        font-weight: 500;
        text-transform: uppercase;
    }

    .services-page-title {
        margin: 18px 0 16px;
        max-width: 24ch;
        font-size: clamp(1.9rem, 3.7vw, 3.2rem);
        line-height: 1.04;
        letter-spacing: -0.05em;
        color: #f3f5f7;
        font-weight: 400;
    }

    .services-page-sub {
        max-width: 90ch;
        margin: 0;
        font-size: 0.98rem;
        line-height: 1.85;
        color: rgba(255,255,255,0.68);
    }

    .services-page-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 20px;
    }

    .services-page-card {
        min-height: 420px;
        padding: 34px 32px;
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.12);
        background:
            radial-gradient(circle at top right, rgba(255,255,255,0.08) 0%, transparent 30%),
            linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
        text-decoration: none;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        position: relative;
        color: #f3f5f7;
        transition: transform 0.22s ease, border-color 0.22s ease, background 0.22s ease;
    }

    .services-page-card:hover {
        transform: translateY(-4px);
        border-color: rgba(255,255,255,0.22);
        background:
            radial-gradient(circle at top right, rgba(255,255,255,0.1) 0%, transparent 30%),
            linear-gradient(180deg, rgba(255,255,255,0.07) 0%, rgba(255,255,255,0.03) 100%);
    }

    .services-card-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 28px;
        padding: 0 12px;
        border-radius: 999px;
        background: #ffffff;
        color: #162436;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        position: absolute;
        top: 26px;
        right: 26px;
    }

    .services-card-icon {
        width: 28px;
        height: 28px;
        color: #ffffff;
        margin-bottom: 34px;
    }

    .services-card-icon svg {
        width: 100%;
        height: 100%;
    }

    .services-card-title {
        margin: 0 0 16px;
        max-width: 11ch;
        font-size: clamp(1.45rem, 2.1vw, 2rem);
        line-height: 1.02;
        letter-spacing: -0.05em;
        font-weight: 400;
        color: #f3f5f7;
    }

    .services-card-body {
        margin: 0;
        max-width: 24ch;
        font-size: 0.98rem;
        line-height: 1.8;
        color: rgba(255,255,255,0.72);
    }

    @@media (max-width: 1024px) {
        .services-page-grid {
            grid-template-columns: 1fr;
        }

        .services-page-card {
            min-height: 320px;
        }
    }

    @@media (max-width: 768px) {
        .services-page {
            padding: 124px 0 64px;
        }

        .services-page-head {
            flex-direction: column;
            margin-bottom: 28px;
        }

        .services-page-title {
            max-width: none;
            font-size: 2.3rem;
        }

        .services-page-card {
            min-height: 280px;
            padding: 26px 24px;
            border-radius: 22px;
        }

        .services-card-title {
            font-size: 1.7rem;
        }

        .services-card-badge {
            top: 22px;
            right: 22px;
        }
    }
</style>

@code {
    protected override void OnInitialized()
    {
        LanguageService.Subscribe(StateHasChanged);
    }

    public void Dispose()
    {
        LanguageService.Unsubscribe(StateHasChanged);
    }
}
