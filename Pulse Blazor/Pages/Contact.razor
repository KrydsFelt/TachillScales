@page "/kontakt"
@inject LanguageService LanguageService
@implements IDisposable

<PageTitle>@(LanguageService.CurrentLanguage == "en" ? "Contact - Tahcill Scales" : "Kontakt - Tahcill Scales")</PageTitle>

<Navigation />

<section class="contact-intro-page">
    <div class="section-inner">
        <div class="contact-intro-wrap">
            <div class="contact-intro-badge">@(LanguageService.CurrentLanguage == "en" ? "BOOK A CALL" : "BOOK ET MØDE")</div>

            <h2 class="contact-intro-title">
                @if (LanguageService.CurrentLanguage == "en")
                {
                    <text>A first conversation if your website needs to feel sharper, calmer, and more complete.</text>
                }
                else
                {
                    <text>En første samtale, hvis jeres website skal føles skarpere, roligere og mere gennemført.</text>
                }
            </h2>

            <p class="contact-intro-body">
                @if (LanguageService.CurrentLanguage == "en")
                {
                    <text>We use the first conversation to understand what needs to be lifted, where the friction is today, and whether we are the right team for the next version.</text>
                }
                else
                {
                    <text>Vi bruger den første samtale på at forstå, hvad der skal løftes, hvor friktionen er i dag, og om vi er det rigtige team til næste version.</text>
                }
            </p>

            <p class="contact-intro-body contact-intro-body-tight">
                @if (LanguageService.CurrentLanguage == "en")
                {
                    <text>No heavy pitch. Just an honest assessment, a few clear angles, and a direction if there is a strong match.</text>
                }
                else
                {
                    <text>Ingen tung pitch. Bare en ærlig vurdering, et par klare vinkler og en retning, hvis der er et godt match.</text>
                }
            </p>

            <div class="contact-meta">
                <div class="contact-meta-row">
                    <span class="contact-meta-label">@(LanguageService.CurrentLanguage == "en" ? "Format" : "Format")</span>
                    <span class="contact-meta-value">@(LanguageService.CurrentLanguage == "en" ? "20-30 min. intro call" : "20-30 min. intro call")</span>
                </div>
            </div>

            <div class="contact-form-shell">
                <div class="contact-form-top">
                    <div class="contact-form-kicker">@(LanguageService.CurrentLanguage == "en" ? "Direct contact" : "Direkte kontakt")</div>
                    <h3 class="contact-form-title">@(LanguageService.CurrentLanguage == "en" ? "Send us an email!" : "Send os en mail!")</h3>
                    <p class="contact-form-top-body">@(LanguageService.CurrentLanguage == "en" ? "Click the button below and your email app opens directly to us." : "Tryk på knappen herunder, så åbner din mail-app direkte til os.")</p>
                </div>

                <a href="mailto:nesar@tahcillscales.com" class="contact-intro-submit">
                    @(LanguageService.CurrentLanguage == "en" ? "Send us an email!" : "Send os en mail!")
                </a>
            </div>
        </div>
    </div>
</section>

<PulseFooter />

<style>
    .contact-intro-page {
        padding: 142px 0 88px;
        background:
            radial-gradient(circle at top left, rgba(103,232,249,0.05) 0%, transparent 22%),
            linear-gradient(180deg, #0d141c 0%, #111922 100%);
    }

    .contact-intro-wrap {
        color: #edf1f4;
    }

    .contact-intro-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 30px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.88);
        font-size: 0.76rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .contact-intro-title {
        margin: 18px 0 20px;
        max-width: 17ch;
        font-size: clamp(2rem, 3vw, 2.5rem);
        line-height: 1.02;
        letter-spacing: -0.05em;
        font-weight: 400;
        color: #edf1f4;
    }

    .contact-intro-body {
        max-width: 78ch;
        margin: 0;
        font-size: 1rem;
        line-height: 1.9;
        color: rgba(255,255,255,0.68);
    }

    .contact-intro-body-tight {
        margin-top: 10px;
    }

    .contact-meta {
        margin-top: 28px;
        display: flex;
        flex-direction: column;
    }

    .contact-meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 16px 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .contact-meta-label {
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.4);
    }

    .contact-meta-value {
        font-size: 0.98rem;
        color: rgba(255,255,255,0.86);
        text-align: right;
    }

    .contact-form-shell {
        margin-top: 28px;
        padding: 28px 26px 30px;
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.1);
        background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(255,255,255,0.01) 100%);
    }

    .contact-form-top {
        margin-bottom: 18px;
    }

    .contact-form-kicker {
        font-size: 0.78rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.52);
    }

    .contact-form-top-body,
    .contact-form-title {
        margin: 10px 0 0;
    }

    .contact-form-title {
        font-size: clamp(1.45rem, 2.4vw, 1.9rem);
        line-height: 1.08;
        letter-spacing: -0.04em;
        font-weight: 400;
        color: #edf1f4;
    }

    .contact-form-top-body {
        margin: 10px 0 0;
        font-size: 0.98rem;
        line-height: 1.8;
        color: rgba(255,255,255,0.68);
    }

    .contact-intro-submit {
        align-self: flex-start;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 176px;
        min-height: 44px;
        padding: 0 20px;
        border-radius: 999px;
        background: #f2eadf;
        color: #162436;
        font-size: 0.86rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        transition: background 0.2s;
    }

    .contact-intro-submit:hover {
        background: #fff7ec;
    }

    @@media (max-width: 768px) {
        .contact-intro-page {
            padding: 124px 0 64px;
        }

        .contact-intro-title {
            max-width: none;
            font-size: 2.9rem;
        }

        .contact-meta-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .contact-meta-value {
            text-align: left;
        }

        .contact-form-shell {
            padding: 22px 18px 22px;
            border-radius: 22px;
        }

        .contact-intro-submit {
            width: 100%;
        }
    }
</style>

@code {
    protected override void OnInitialized()
    {
        LanguageService.Subscribe(StateHasChanged);
    }

    public void Dispose()
    {
        LanguageService.Unsubscribe(StateHasChanged);
    }
}
