                <h3 class="oo-team-name">Navn 1</h3>
                <p class="oo-team-role">Founder & Strategy</p>
                <a href="mailto:contact@tahcill.dk" class="oo-team-link">Kontakt →</a>
            </div>

            <div class="oo-team-card" data-animate="fade-up" data-delay="100">
                <div class="oo-team-image" style="background-image: url('/images/team/person-2.jpg')"></div>
