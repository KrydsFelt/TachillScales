<Navigation />

<!-- ══ HERO ══ -->
<section class="oo-hero">
    <div class="section-inner">
        <div class="oo-hero-content" data-animate="fade-up">
            <div class="oo-hero-eyebrow">OM OS</div>
            <h1 class="oo-hero-title">Et team med ét mål<br/>— din vækst.</h1>
            <p class="oo-hero-sub">Vi er ikke et bureau der tæller kliks. Vi er en partner der forstår din forretning og bygger strategier der holder — baseret på data, erfaring og resultat.</p>
        </div>
    </div>
</section>

